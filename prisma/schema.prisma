generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id    String @id @default(cuid())
  name  String
  plan  String
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  name     String
  role     String
  tenantId String
}

model Integration {
  id       String   @id @default(cuid())
  provider String
  name     String
  status   String
  active   Boolean  @default(true)
  config   Json
  tenantId String
}

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String
  active      Boolean  @default(true)
  trigger     String?
  nodes       Json
  edges       Json?
  tenantId    String
}

model Pipeline {
  id           String @id @default(cuid())
  name         String
  stages       Json
  customFields Json
  tenantId     String
}

model Deal {
  id           String   @id @default(cuid())
  title        String
  value        Float    @default(0)
  company      String
  contactId    String
  stageId      String
  pipelineId   String
  priority     String
  status       String
  customValues Json
  assignedTo   String
  createdAt    DateTime @default(now())
  tenantId     String
}

model Conversation {
  id              String   @id @default(cuid())
  tenantId        String
  contactId       String
  contactName     String
  contactAvatar   String
  lastMessage     String
  lastMessageTime DateTime @default(now())
  unreadCount     Int      @default(0)
  channel         String
  status          String   @default("open")
  createdAt       DateTime @default(now())
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  tenantId       String
  senderId       String?
  contactId      String?
  content        String
  channel        String
  timestamp      DateTime @default(now())
}

model ModuleDefinition {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  slug        String   @unique
  icon        String
  description String
  fields      Json
  createdAt   DateTime @default(now())
}

model ModuleRecord {
  id        String   @id @default(cuid())
  moduleId  String
  tenantId  String
  data      Json
  createdAt DateTime @default(now())
}

model Appointment {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  type        String
  contactId   String?
  location    String?
  status      String
  createdAt   DateTime @default(now())
}
